# Example configuration for Sec-Cam
# Copy this to .env and set BOT_TOKEN and CHAT_ID

BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
CHAT_ID="YOUR_CHAT_ID"

# Camera settings
CAMERA_ID=0

# Detection tuning
DETECTION_INTERVAL=1.0
DETECTION_WIDTH=160
DETECTION_HEIGHT=120
DETECTION_ALPHA=0.05
PIXEL_THRESHOLD=25
MOTION_RATIO_THRESHOLD=0.02
MIN_MOTION_FRAMES=3

# Recording
RECORD_DURATION=10
RECORD_FRAME_INTERVAL=0.5
COOLDOWN=60

# Paths
TMP_DIR="/data/data/com.termux/files/home/sec-cam/tmp"

# ffmpeg and validation
# FFMPEG_PRESET: ultafaster presets speed vs size (ultrafast is fastest)
# FFMPEG_CRF: quality (higher = smaller/faster, 0-51)
# VALIDATE_VIDEO: when true, run a read-check with ffmpeg on produced mp4 files; set to 0 to skip validation for speed
FFMPEG_PRESET=ultrafast
FFMPEG_CRF=36
VALIDATE_VIDEO=0
